---
import '../styles/global.css';
import Navbar from '../components/nav/Navbar';
import Footer from '../components/nav/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', 'GTM-WLSLX74Z');
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/CC_logo_fav_32_px.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{'Core Collective - ' + title}</title>
  </head>
  <body class="bg-cc-blue --font-sans flex min-h-screen flex-col">
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-WLSLX74Z"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <Navbar client:load />
    <main
      class="bg-cc-blue flex grow flex-col items-center justify-center text-center text-white"
    >
      <slot />
    </main>
    <Footer />
  </body>

  <style>
    html,
    body {
      margin: 0;
      width: 100%;
      overflow-x: hidden;
    }
  </style>
</html>
