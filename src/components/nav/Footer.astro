---
import LogoImg from '../../assets/CC_logo_no_tag.svg';
import { Icon } from 'astro-icon/components';

const navLinks = [
  { name: 'Working Groups', href: '/working-groups/' },
  { name: 'About', href: '/about/' },
  { name: 'Join', href: '/join/' },
  { name: 'Blog & News', href: '/blog/' },
  { name: 'Contact', href: '/contact/' },
];

const socials = [
  { label: 'X', url: 'https://x.com/corecollectivee', icon: 'X' },
  {
    label: 'Bluesky',
    url: 'https://bsky.app/profile/thecorecollective.bsky.social',
    icon: 'bluesky',
  },
  {
    label: 'Linkedin',
    url: 'https://www.linkedin.com/company/corecollective-dev/',
    icon: 'linkedin',
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-cc-dark w-full px-4 py-12 text-white">
  <div class="mx-auto max-w-7xl">
    <div
      class="flex flex-col items-center justify-between space-y-8 border-b border-white/10 pb-10 lg:flex-row lg:space-y-0"
    >
      <div class="flex flex-1 flex-col items-center justify-start">
        <a href="/">
          <img src={LogoImg.src} alt="Logo" class="h-24 w-auto" />
        </a>
        <ul class="not-prose flex flex-wrap gap-2">
          {
            socials.map((social) => (
              <li class="p-3">
                <a href={social.url} target="_blank" aria-label={social.label}>
                  <Icon
                    name={social.icon}
                    size={20}
                    class="hover:text-cc-cyan text-white"
                  />
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <nav class="flex">
        <ul class="flex flex-wrap justify-center">
          {
            navLinks.map((link) => (
              <li class="border-cc-cyan flex h-6 items-center border-r-2 px-6 last:border-r-0">
                <a
                  href={link.href}
                  class="hover:text-cc-cyan text-sm text-white transition-colors"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="flex flex-1 justify-end">
        <a
          href="/coc/"
          class="text-cc-cyan border-r-2 border-white px-4 text-xs hover:text-white"
        >
          Code of Conduct
        </a>
        <a
          href="/ai-policy/"
          class="text-cc-cyan border-r-2 border-white px-4 text-xs hover:text-white"
        >
          AI Policy
        </a>
        <a
          href="/antitrust-policy/"
          class="text-cc-cyan px-4 text-xs hover:text-white"
        >
          Anti-Trust Policy
        </a>
      </div>
    </div>

    <div class="pt-8 text-center">
      <p class="text-xs text-gray-600">
        &copy;Linaro Group {currentYear}
      </p>
    </div>
  </div>
</footer>
