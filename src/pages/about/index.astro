---
import Contact from '../../components/Contact.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import aboutTitle from '../../assets/about 1.png';
import { Image } from 'astro:assets';
import backgroundImage from '../../assets/0233f2c4c9a0817f3a88064a357678647bb97e85.png';
import developersImage from '../../assets/developers.png';
import PageTitle from '../../components/PageTitle.astro';
import Leadership from '../../components/Leadership.astro';
---

<BaseLayout title="About">
  <div
    class="flex w-full flex-col items-center gap-16 py-14 md:px-32"
    style={{
      backgroundImage: `url(${backgroundImage.src})`,
      backgroundSize: 'cover',
      backgroundPosition: 'center',
    }}
  >
    <PageTitle path={aboutTitle} />
    <div
      class="flex flex-col gap-8 text-left text-lg font-light text-white md:mx-24 md:text-2xl"
    >
      <div
        class="flex flex-col-reverse items-center gap-8 md:flex-row md:gap-0"
      >
        <Image
          src={developersImage}
          alt="developers talking image"
          class="h-auto w-full shrink-0 rounded-lg object-cover md:w-2/5"
        />
        <div
          class="mx-4 flex flex-1 flex-col gap-8 py-6 md:mx-0 md:px-4 md:py-0"
        >
          <p class="">
            The Arm ecosystem has grown far beyond mobile, now spanning AI,
            cloud, edge, automotive, and client compute. As the ecosystem has
            expanded and technology evolved, software complexity has increased.
            No single company can maintain enablement alone - open source
            collaboration is key.
          </p>
          <p>
            <span class="font-bold">CoreCollective </span>provides a neutral
            platform for innovators in the Arm ecosystem to come together and
            openly collaborate on common requirements. By working together on
            the common needs once, companies can focus more of their efforts and
            resources on differentiating their product.
          </p>
        </div>
      </div>

      <div class="mx-4 flex flex-col gap-8 lg:mx-auto">
        <p class="font-extrabold">
          CoreCollective comprises multiple Working Groups, each focused on a
          specific technology. Any company is free to join and participate in
          CoreCollective.
        </p>
        <p>
          To better understand options to join, as well as enhancing your
          membership to increase visibility and influence, <a
            class="text-cc-cyan"
            href="/join/">click here.</a
          >
        </p>
        <p>
          To see the benefits of joining as well as the current active Working
          Groups, please download our <a
            class="text-cc-cyan no-underline"
            href="https://static.corecollective.dev/assets/CoreCollective+Pitch+Deck+v1.2.pdf"
            target="_blank">short slide deck</a
          >
        </p>
      </div>
    </div>
  </div>
  <Leadership />
  <Contact />
</BaseLayout>
