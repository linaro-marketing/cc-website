---
import BaseLayout from '../layouts/BaseLayout.astro';
import LogoImg from '../assets/CC_logo_no_tag.svg';
---

<BaseLayout title="Page Not Found">
  <div class="flex min-h-[calc(100vh-10rem)] flex-col">
    <main
      class="flex grow flex-col items-center justify-center px-4 text-center"
    >
      <div class="max-w-xl space-y-8">
        <h1
          class="text-9xl font-black tracking-tighter text-white opacity-10 sm:text-[10rem]"
        >
          404
        </h1>

        <div class="-mt-16 space-y-4 sm:-mt-20">
          <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
            Page not found
          </h2>
          <p class="text-lg text-blue-100/80">
            Sorry, we couldn't find the page you're looking for. It might have
            been moved or deleted.
          </p>
        </div>

        <div class="pt-6">
          <a
            href="/"
            class="text-cc-blue inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-base font-bold transition-all duration-200 hover:scale-105 hover:bg-blue-50 hover:shadow-[0_0_20px_rgba(255,255,255,0.3)]"
          >
            Take me home
          </a>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
